{
  "name": "stream",
  "productName": "Stream",
  "version": "1.0.0",
  "description": "Custom IPTV Player with Apple TV style interface",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --dir",
    "pack": "electron-builder"
  },
  "build": {
    "appId": "com.stream.iptv",
    "productName": "Stream",
    "icon": "assets/icon",
    "publish": {
      "provider": "github",
      "owner": "YOUR_GITHUB_USERNAME",
      "repo": "stream-iptv"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.1.7",
    "m3u-parser-generator": "^2.0.0"
  }


}
